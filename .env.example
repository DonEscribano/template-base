# ═══════════════════════════════════════════
# TEMPLATE-BASE — Variables de entorno
# ═══════════════════════════════════════════
# Copia este archivo a .env.local y rellena los valores

# ─── Supabase (OBLIGATORIO) ───
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Resend — emails transaccionales (OBLIGATORIO) ───
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=info@tudominio.es
NOTIFICATION_EMAIL=mario@tudominio.es

# ─── Sentry — monitorización errores (RECOMENDADO) ───
SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...

# ─── WhatsApp Business API (OPCIONAL) ───
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=
# Templates aprobados por Meta (rellenar tras aprobación)
WHATSAPP_TEMPLATE_BOOKING_CONFIRMATION=
WHATSAPP_TEMPLATE_REMINDER_24H=
WHATSAPP_TEMPLATE_REMINDER_2H=

# ─── Stripe — pagos (OPCIONAL) ───
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...

# ─── Analytics (OPCIONAL) ───
NEXT_PUBLIC_GA4_ID=G-...
NEXT_PUBLIC_META_PIXEL_ID=

# ─── Rate Limiting — Upstash Redis (RECOMENDADO para producción) ───
# Sin estas vars, usa rate limiting en memoria (menos fiable en serverless)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Cron Secret (OBLIGATORIO para crons) ───
CRON_SECRET=

# ─── Site Config (se lee en lib/config/site.ts) ───
NEXT_PUBLIC_SITE_NAME=Mi Negocio
NEXT_PUBLIC_SITE_URL=https://minegocio.es
